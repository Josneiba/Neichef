generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String               @id
  email                 String               @unique
  name                  String
  householdSize         Int                  @default(1)
  dietaryPreferences    String[]
  notificationDaysAhead Int                  @default(3)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  pantryItems           PantryItem[]
  recipes               Recipe[]
  savedRecipes          SavedRecipe[]
  notifications         Notification[]
  budgetLedgerEntries   BudgetLedgerEntry[]
}

model PantryItem {
  id              String               @id @default(cuid())
  userId          String
  name            String
  category        String
  quantity        Float
  unit            String
  expirationDate  DateTime
  location        String
  addedDate       DateTime             @default(now())
  imageUrl        String?
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetEntries   BudgetLedgerEntry[]

  @@index([userId])
}

model Recipe {
  id                  String               @id @default(cuid())
  userId              String?
  source              String               @default("user")
  externalId          String?
  title               String
  description         String
  prepTimeMinutes     Int
  cookTimeMinutes     Int
  servings            Int
  difficulty          String
  tags                String[]
  imageUrl            String?
  costLevel           String
  isPublic            Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredients         RecipeIngredient[]
  steps               RecipeStep[]
  savedBy             SavedRecipe[]
  notifications       Notification[]

  @@index([userId])
  @@index([source, externalId])
}

model RecipeIngredient {
  id            String  @id @default(cuid())
  recipeId      String
  name          String
  amount        Float
  unit          String
  substitution  String?
  recipe        Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model RecipeStep {
  id               String  @id @default(cuid())
  recipeId         String
  step             Int
  instruction      String
  durationMinutes  Int?
  recipe           Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model SavedRecipe {
  userId    String
  recipeId  String
  savedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([userId, recipeId])
  @@index([recipeId])
}

model Notification {
  id               String   @id @default(cuid())
  userId           String
  type             String
  title            String
  message          String
  itemId           String?
  recipeId         String?
  createdAt        DateTime @default(now())
  isRead           Boolean  @default(false)
  daysUntilExpiry  Int?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe           Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
}

model BudgetLedgerEntry {
  id            String      @id @default(cuid())
  userId        String
  pantryItemId  String?
  type          String
  amount        Float
  occurredAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pantryItem    PantryItem? @relation(fields: [pantryItemId], references: [id], onDelete: SetNull)

  @@index([userId])
}
